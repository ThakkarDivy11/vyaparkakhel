# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000
HOST=localhost
API_VERSION=v1
BASE_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/your_database_name
MONGODB_TEST_URI=mongodb://localhost:27017/your_database_name_test
MONGODB_USER=your_mongo_username
MONGODB_PASSWORD=your_mongo_password
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=your_database_name

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=your_database_name
POSTGRES_USER=your_postgres_username
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_SSL=false
DATABASE_URL=postgresql://your_postgres_username:your_postgres_password@localhost:5432/your_database_name
DATABASE_TEST_URL=postgresql://your_postgres_username:your_postgres_password@localhost:5432/your_database_name_test

# Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_min_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=your-app-name
JWT_AUDIENCE=your-app-users

# Session Configuration
SESSION_SECRET=your_session_secret_key_min_32_characters_long
SESSION_NAME=sessionId
SESSION_MAX_AGE=86400000
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

# Password Hashing
BCRYPT_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# =============================================================================
# OAUTH & SOCIAL AUTHENTICATION
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Twitter OAuth
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
TWITTER_CALLBACK_URL=http://localhost:3000/auth/twitter/callback

# =============================================================================
# FILE UPLOAD & STORAGE
# =============================================================================

# Multer Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain
MAX_FILES_PER_REQUEST=10

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_PUBLIC_URL=https://your-s3-bucket-name.s3.amazonaws.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_SECURE=true

# Local Storage Configuration
STATIC_FILES_PATH=public
UPLOAD_PATH=public/uploads
TEMP_UPLOAD_PATH=tmp/uploads

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your App Name

# Mailgun Configuration
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Email Templates
EMAIL_VERIFICATION_TEMPLATE=email_verification
PASSWORD_RESET_TEMPLATE=password_reset
WELCOME_EMAIL_TEMPLATE=welcome

# =============================================================================
# EXTERNAL SERVICES & APIs
# =============================================================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_PREFIX=app:
REDIS_TTL=3600

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_EXCHANGE=app_exchange
RABBITMQ_QUEUE=app_queue

# Payment Gateway Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# =============================================================================
# WEBHOOKS
# =============================================================================

# Webhook Security
WEBHOOK_SECRET=your_webhook_secret_key
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# Third-party Webhook URLs
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/discord/webhook
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/your/teams/webhook

# Custom Webhook Endpoints
USER_REGISTRATION_WEBHOOK=http://localhost:3001/webhooks/user-registration
PAYMENT_SUCCESS_WEBHOOK=http://localhost:3001/webhooks/payment-success
ORDER_STATUS_WEBHOOK=http://localhost:3001/webhooks/order-status

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Winston Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14
LOG_DATE_PATTERN=YYYY-MM-DD

# Sentry Configuration
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# New Relic Configuration
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=your-app-name

# DataDog Configuration
DD_API_KEY=your_datadog_api_key
DD_SERVICE=your-service-name
DD_ENV=development

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Cache Settings
CACHE_TTL=300
CACHE_MAX_KEYS=1000
CACHE_CHECK_PERIOD=120

# Memcached Configuration
MEMCACHED_HOST=localhost
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=your_memcached_username
MEMCACHED_PASSWORD=your_memcached_password

# =============================================================================
# SEARCH & INDEXING
# =============================================================================

# Elasticsearch Configuration
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=your_app_index
ELASTICSEARCH_USERNAME=your_elasticsearch_username
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# Algolia Configuration
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_API_KEY=your_algolia_api_key
ALGOLIA_SEARCH_KEY=your_algolia_search_key
ALGOLIA_INDEX_NAME=your_algolia_index

# =============================================================================
# NOTIFICATION SERVICES
# =============================================================================

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_CLIENT_ID=your_firebase_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# OneSignal Configuration
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Development Tools
DEBUG=app:*
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs
API_DOCS_PASSWORD=your_api_docs_password

# Testing Configuration
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_database
TEST_MONGODB_URI=mongodb://localhost:27017/test_database
JEST_TIMEOUT=10000
TEST_COVERAGE_THRESHOLD=80

# Mock/Stub Configuration
MOCK_EXTERNAL_APIS=false
STUB_EMAIL_SERVICE=true
STUB_PAYMENT_SERVICE=true

# =============================================================================
# PERFORMANCE & OPTIMIZATION
# =============================================================================

# Compression
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# Request Limits
REQUEST_SIZE_LIMIT=10mb
PARAMETER_LIMIT=1000
URL_LENGTH_LIMIT=2048

# Connection Limits
MAX_CONNECTIONS=100
KEEP_ALIVE_TIMEOUT=5000
HEADERS_TIMEOUT=60000

# =============================================================================
# SECURITY HEADERS & PROTECTION
# =============================================================================

# Helmet Configuration
HELMET_CONTENT_SECURITY_POLICY=default-src 'self'
HELMET_REFERRER_POLICY=same-origin
HELMET_HSTS_MAX_AGE=31536000
HELMET_X_FRAME_OPTIONS=DENY

# Additional Security
TRUST_PROXY=false
IP_WHITELIST=127.0.0.1,::1
ADMIN_IPS=127.0.0.1,192.168.1.100

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature Toggles
FEATURE_USER_REGISTRATION=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_EMAIL_VERIFICATION=true
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_ADMIN_PANEL=true
FEATURE_ANALYTICS=true
FEATURE_MAINTENANCE_MODE=false

# =============================================================================
# MISCELLANEOUS
# =============================================================================

# Time Zone
TZ=UTC
DEFAULT_TIMEZONE=America/New_York

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# API Versioning
API_DEPRECATION_WARNING=false
DEPRECATED_VERSIONS=v1,v2

# Background Jobs
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000